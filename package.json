{
  "name": "spinixads",
  "displayName": "Spinix — distribution for builders",
  "description": "Get pinged when your AI agent finishes. While it thinks, its spinner shows indie products from the cross-promo ring and perks from AI companies. Track who made the AI think the most.",
  "version": "2.0.0",
  "publisher": "spinixads",
  "type": "commonjs",
  "icon": "media/icon.png",
  "license": "MIT",
  "homepage": "https://spinixads.com",
  "repository": { "type": "git", "url": "https://github.com/pranavred/spinix-vscode.git" },
  "bugs": { "url": "https://github.com/pranavred/spinix-vscode/issues" },
  "pricing": "Free",
  "galleryBanner": { "color": "#10151b", "theme": "dark" },
  "keywords": ["notify", "notification", "claude-code", "codex", "agent", "perks", "offers", "spinner", "statusline"],
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "spinix.signIn", "title": "Spinix: Sign in" },
      { "command": "spinix.signOut", "title": "Spinix: Sign out" },
      { "command": "spinix.restore", "title": "Spinix: Restore Claude Code" },
      { "command": "spinix.status", "title": "Spinix: Show status" },
      { "command": "spinix.enable", "title": "Spinix: Enable" },
      { "command": "spinix.disable", "title": "Spinix: Disable" },
      { "command": "spinix.openAd", "title": "Spinix: Open the current offer" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "spinix.openAd", "when": "false" }
      ]
    },
    "configuration": {
      "title": "Spinix",
      "properties": {
        "spinix.backendUrl": { "type": "string", "default": "https://spinixads.com", "scope": "application", "description": "Spinix backend base URL." },
        "spinix.enabled": { "type": "boolean", "default": true, "description": "Show the Spinix line in the Claude Code spinner: cross-promo ring products and perks from AI companies." },
        "spinix.notify": { "type": "boolean", "default": true, "description": "Show a desktop notification the moment your agent finishes. It takes effect immediately, your think-time still counts on the board either way, and it's fully reversible." }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js --format=cjs && cp src/statusline.mjs dist/statusline.mjs && cp src/poster.mjs dist/poster.mjs && cp src/notify.mjs dist/notify.mjs",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "npx --yes ovsx publish --no-dependencies",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
